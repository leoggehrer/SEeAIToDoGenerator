    {
      "parameters": {
        "jsCode": "// Check if AI response contains save command\nconst aiOutput = $input.first().json.output || $input.first().json.text || '';\n\n// Look for the JSON save command in the response\nconst jsonMatch = aiOutput.match(/```json\\s*\\n?({[\\s\\S]*?\"action\"\\s*:\\s*\"SAVE_TODO_LIST\"[\\s\\S]*?})\\s*\\n?```/);\n\nif (jsonMatch) {\n  try {\n    const saveData = JSON.parse(jsonMatch[1]);\n    \n    if (saveData.action === 'SAVE_TODO_LIST' && saveData.data) {\n      // Clean the response text (remove JSON block for display)\n      const cleanResponse = aiOutput.replace(/```json[\\s\\S]*?```/g, '').trim();\n      \n      return {\n        json: {\n          shouldSave: true,\n          aiResponse: cleanResponse,\n          toDoList: saveData.data,\n          originalResponse: aiOutput\n        }\n      };\n    }\n  } catch (e) {\n    // JSON parsing failed, continue as normal chat\n  }\n}\n\n// No save command, just return chat response\nreturn {\n  json: {\n    shouldSave: false,\n    aiResponse: aiOutput,\n    toDoList: null\n  }\n};"
      },
