        "parameters": {
          "jsCode": "// Get the list ID and prepare items for insert\nconst listResult = $('InsertToDoList').first().json;\nconst prepareResult = $('PrepareToDoList').first().json;\n\nconst listId = listResult.Id;\nconst items = prepareResult.items;\nconst now = new Date().toISOString();\n\nif (!items || items.length === 0) {\n  return [];\n}\n\n// Return items with list reference\nreturn items.map(item => ({\n  json: {\n    ToDoListId: listId,\n    Name: item.name,\n    Description: item.description || '',\n    Priority: item.priority || 2,\n    State: 1, // Open\n    DueDate: item.dueDate || null,\n    CompletedOn: null,\n    IsCompleted: false,\n    CreatedOn: now,\n    ModifiedOn: now\n  }\n}));"
        },
