          "jsCode": "// Build final response after save\nconst listResult = $('InsertToDoList').first().json;\nconst itemsResult = $('InsertToDoItems').all();\nconst prepareResult = $('PrepareToDoList').first().json;\n\nconst response = prepareResult.aiResponse + \n  '\\n\\n✅ **Liste wurde gespeichert!**\\n' +\n  '- Listen-ID: ' + listResult.Id + '\\n' +\n  '- Anzahl Aufgaben: ' + itemsResult.length;\n\nreturn {\n  json: {\n    output: response\n  }\n};"
