      "parameters": {
        "jsCode": "// Prepare ToDoList data for database insert\nconst input = $input.first().json;\nconst toDoList = input.toDoList;\nconst now = new Date().toISOString();\n\nreturn {\n  json: {\n    Name: toDoList.listName || 'Neue ToDo-Liste',\n    Description: toDoList.listDescription || '',\n    Type: toDoList.listType || 1,\n    IdentityId: null,\n    CreatedOn: now,\n    ModifiedOn: now,\n    items: toDoList.items || [],\n    aiResponse: input.aiResponse\n  }\n};"
      },
